# --- CONFIGURACIÓN DE BASE DE DATOS (POSTGRES) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=callcenter_db
# Esta URL es la que usará SQLAlchemy
DATABASE_URL=postgresql://user:password@db:5432/callcenter_db

# --- CONFIGURACIÓN DE MENSAJERÍA (RABBITMQ) ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=rabbitmq

# --- CONFIGURACIÓN DE LA APP ---
PROJECT_NAME="AI Call Center - Reception API"
DEBUG=True