# --- CONFIGURACIÓN DE BASE DE DATOS (POSTGRES) ---
# Estos valores definen cómo se crea la base de datos en el contenedor
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=callcenter_db

# Esta es la URL de conexión que usarán la API y el Worker.
# "db" es el nombre del servicio en el docker-compose.
DATABASE_URL=postgresql://user:password@db:5432/callcenter_db

# --- CONFIGURACIÓN DE MENSAJERÍA (RABBITMQ) ---
# "guest" es el usuario por defecto de RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
# "rabbitmq" es el nombre del servicio en el docker-compose
RABBITMQ_HOST=rabbitmq

# --- CONFIGURACIÓN DE LA APP ---
PROJECT_NAME="AI Call Center - Sistema Integral"
DEBUG=True
